function renderMap(cars){
  if(!mapObj){
    mapObj=L.map('map',{zoomControl:true}).setView([37.56,126.93],11);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
      attribution:'© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',maxZoom:18
    }).addTo(mapObj);
  }
  mapLayers.forEach(l=>mapObj.removeLayer(l));
  mapLayers=[];

  const depotM=L.marker([DEPOT.lat,DEPOT.lng],{icon:makeDepotIcon()})
    .bindPopup('<b>★ 물류 출발지</b><br>김포 고촌읍 아라육로57번길 45');
  depotM.addTo(mapObj);
  mapLayers.push(depotM);

  const bounds=[[DEPOT.lat,DEPOT.lng]];

  cars.forEach((c,ci)=>{
    if(!c.length) return;
    const cc=CC[ci]||CC[0];
    const pts=[[DEPOT.lat,DEPOT.lng],...c.map(p=>{
      const pos=getPos(p);
      bounds.push([pos.lat,pos.lng]);
      return[pos.lat,pos.lng];
    })];
    const line=L.polyline(pts,{color:cc.hex,weight:2.5,opacity:0.7,dashArray:'7,5'});
    line.addTo(mapObj);
    mapLayers.push(line);

    c.forEach((p,i)=>{
      const pos=getPos(p);
      const w=getWin(p);
      const isWarn=w.type!=='free';
      const marker=L.marker([pos.lat,pos.lng],{icon:makeIcon(cc.hex,i+1,isWarn)});
      const mins=21*60+i*15;
      const th=Math.floor(mins/60)%24,tm=mins%60;
      const et=String(th).padStart(2,'0')+":"+String(tm).padStart(2,'0');
      marker.bindPopup(
        `<b>${p.n}</b><br>`+
        `<span style="font-size:11px;color:#555;">${p.addr}</span><br>`+
        `<span style="font-size:11px;">${cc.n} ${i+1}번째 &nbsp;|&nbsp; 예상 ${et}</span>`+
        (w.type!=='free'?`<br><span style="font-size:11px;color:#D85A30;font-weight:500;">${w.label}</span>`:'')
      );
      marker.addTo(mapObj);
      mapLayers.push(marker);
    });
  });

  if(bounds.length>1) mapObj.fitBounds(bounds,{padding:[28,28]});

  const legendHtml=cars.map((c,ci)=>{
    if(!c.length) return'';
    const cc=CC[ci]||CC[0];
    return`<div class="leg-item"><div class="leg-dot" style="background:${cc.hex};"></div><span>${cc.n} (${c.length}개소)</span></div>`;
  }).join('');
  document.getElementById("legend").innerHTML=
    `<div class="leg-item"><div class="leg-sq" style="background:#1a1a1a;"></div><span>물류 출발지</span></div>`+
    legendHtml+
    `<div class="leg-item"><div class="leg-dot" style="background:#D85A30;"></div><span>시간제약 약국</span></div>`;
}

function build(){
  if(!sel.size){alert("약국을 선택해주세요");return;}
  const vcnt=parseInt(document.getElementById("vcnt").value)||4;
  const list=RAW.filter(p=>sel.has(p.id));

  const before=list.filter(p=>getWin(p).type==='before').sort((a,b)=>getWin(a).deadline-getWin(b).deadline);
  const after=list.filter(p=>getWin(p).type==='after').sort((a,b)=>getWin(a).available-getWin(b).available);
  const blocked=list.filter(p=>getWin(p).type==='blocked');
  const free=list.filter(p=>getWin(p).type==='free');
  const constrained=[...before,...after];

  const cars=Array.from({length:vcnt},()=>[]);
  const freeSort=[...free].sort((a,b)=>guAngle(a.g)-guAngle(b.g));
  if(freeSort.length){
    const chunk=Math.ceil(freeSort.length/vcnt);
    freeSort.forEach((p,i)=>cars[Math.min(Math.floor(i/chunk),vcnt-1)].push(p));
  }
  constrained.forEach(p=>{
    const ang=guAngle(p.g);
    let best=0,bDist=Infinity;
    cars.forEach((c,i)=>{
      const ref=c.length?c.reduce((s,x)=>s+guAngle(x.g),0)/c.length:ang;
      const d=Math.abs(ang-ref);
      if(d<bDist){bDist=d;best=i;}
    });
    cars[best].unshift(p);
  });
  cars.forEach(c=>{
    const b=c.filter(p=>getWin(p).type==='before').sort((a,b2)=>getWin(a).deadline-getWin(b2).deadline);
    const a=c.filter(p=>getWin(p).type==='after').sort((a2,b2)=>getWin(a2).available-getWin(b2).available);
    const n=c.filter(p=>getWin(p).type==='free').sort((a2,b2)=>guDist(a2.g)-guDist(b2.g));
    c.length=0;c.push(...b,...a,...n);
  });

  let alertHtml='';
  if(blocked.length) alertHtml+=`<div class="abox aw">배송시간 전체 폐쇄 — 배송 불가 ${blocked.length}개: ${blocked.map(p=>p.n).join(', ')}</div>`;
  if(before.length) alertHtml+=`<div class="abox ai">마감 전 배송 필수 ${before.length}개 → 각 차량 앞순위 배정</div>`;
  if(after.length) alertHtml+=`<div class="abox ai">폐쇄 종료 후 배송 ${after.length}개 → 각 차량 앞순위 배정</div>`;
  document.getElementById("alerts").innerHTML=alertHtml;

  const cols=vcnt===1?'1fr':vcnt<=2?'1fr 1fr':vcnt===3?'repeat(3,1fr)':'repeat(2,1fr)';
  document.getElementById("cargrid").style.gridTemplateColumns=cols;
  document.getElementById("cargrid").innerHTML=cars.map((c,ci)=>{
    const cc=CC[ci]||CC[0];
    if(!c.length) return`<div class="cc"><div class="ch"><div class="cbadge" style="background:${cc.bg};color:${cc.txt};">0</div><div><div class="ct">${cc.n}</div><div class="cm">배정 없음</div></div></div></div>`;
    const zones=[...new Set(c.map(p=>p.g))];
    const warnCnt=c.filter(p=>getWin(p).type!=='free').length;
    const estEnd=21*60+c.length*15;
    const eh=Math.floor(estEnd/60)%24,em=estEnd%60;
    const minDist=Math.round(Math.min(...zones.map(g=>guDist(g))));
    const rows=c.map((p,i)=>{
      const w=getWin(p);
      const mins=21*60+i*15;
      const th=Math.floor(mins/60)%24,tm=mins%60;
      const et=String(th).padStart(2,'0')+":"+String(tm).padStart(2,'0');
      return`<div class="ri">
        <div class="sn" style="background:${cc.bg};color:${cc.txt};">${i+1}</div>
        <div style="flex:1;min-width:0;">
          <div class="rname">${p.n}</div>
          <div class="raddr">${p.addr}</div>
          ${w.type!=='free'?`<div class="rw">${winTagHtml(w)}</div>`:''}
        </div>
        <span class="rtime" style="color:${cc.txt};">${et}</span>
      </div>`;
    }).join('');
    return`<div class="cc" style="border-color:${cc.hex}40;">
      <div class="ch">
        <div class="cbadge" style="background:${cc.bg};color:${cc.txt};">${c.length}</div>
        <div><div class="ct">${cc.n}</div><div class="cm">거점까지 최근 약 ${minDist}km &nbsp;·&nbsp; 시간제약 ${warnCnt}개</div></div>
      </div>
      <div class="zpills">${zones.map(g=>`<span class="zp" style="background:${cc.bg};color:${cc.txt};">${g}</span>`).join('')}</div>
      <div style="max-height:300px;overflow-y:auto;">${rows}</div>
      <div class="cstat">
        <div class="cs">출발 <span>21:00</span></div>
        <div class="cs">예상완료 <span>${String(eh).padStart(2,'0')}:${String(em).padStart(2,'0')}</span></div>
        <div class="cs">총 <span>${c.length}개소</span></div>
      </div>
    </div>`;
  }).join('');

  document.getElementById("result").style.display='block';
  switchTab('map');
  setTimeout(()=>renderMap(cars),120);
  document.getElementById("result").scrollIntoView({behavior:'smooth',block:'start'});
}

(function init(){
  const gus=[...new Set(RAW.map(p=>p.g))].sort();
  const sg=document.getElementById("sg");
  gus.forEach(g=>{const o=document.createElement("option");o.value=g;o.textContent=g;sg.appendChild(o);});
  const wc=RAW.filter(p=>p.fs&&p.fs!=="없음").length;
  document.getElementById("metrics").innerHTML=`
    <div class="metric"><div class="metric-val">${RAW.length}</div><div class="metric-lbl">전체 약국</div></div>
    <div class="metric"><div class="metric-val">${wc}</div><div class="metric-lbl">건물폐쇄 약국</div></div>
    <div class="metric"><div class="metric-val">1~5대</div><div class="metric-lbl">배송 차량 (가변)</div></div>
    <div class="metric"><div class="metric-val">21~02시</div><div class="metric-lbl">배송 시간대</div></div>
  `;
  rf();
})();
</script>
