function winTagHtml(w){
  if(w.type==='free') return'';
  if(w.type==='before') return`<span class="win-tag win-before">${w.label}</span>`;
  if(w.type==='after') return`<span class="win-tag win-after">${w.label}</span>`;
  if(w.type==='blocked') return`<span class="win-tag win-blocked">${w.label}</span>`;
  return'';
}

function rf(){
  const q=document.getElementById("sq").value.toLowerCase();
  const g=document.getElementById("sg").value;
  const c=document.getElementById("scf").value;
  const f=RAW.filter(p=>{
    const qm=!q||(p.n.toLowerCase().includes(q)||p.addr.toLowerCase().includes(q));
    const gm=!g||p.g===g;
    const hc=p.fs&&p.fs!=="없음";
    const cm=c===''||(c==='y'&&hc)||(c==='n'&&!hc);
    return qm&&gm&&cm;
  });
  const el=document.getElementById("plist");
  if(!f.length){el.innerHTML='<div style="text-align:center;padding:1.5rem;font-size:13px;color:#888;">검색 결과 없음</div>';return;}
  el.innerHTML=f.map(p=>{
    const on=sel.has(p.id);
    const w=getWin(p);
    const hc=p.fs&&p.fs!=="없음";
    return`<div class="pi${on?' sel':''}" onclick="tog(${p.id})">
      <div class="chk${on?' on':''}">${on?'✓':''}</div>
      <div style="flex:1;min-width:0;">
        <div style="font-size:13px;font-weight:500;">${p.n}</div>
        <div style="font-size:11px;color:#888;">${p.addr}</div>
      </div>
      ${hc?winTagHtml(w):''}
    </div>`;
  }).join('');
  document.getElementById("scnt").textContent=sel.size+"개 선택됨";
}

function tog(id){sel.has(id)?sel.delete(id):sel.add(id);rf();}
function sa(){
  const q=document.getElementById("sq").value.toLowerCase();
  const g=document.getElementById("sg").value;
  RAW.filter(p=>(!q||(p.n.toLowerCase().includes(q)||p.addr.toLowerCase().includes(q)))&&(!g||p.g===g)).forEach(p=>sel.add(p.id));
  rf();
}
function ca(){sel.clear();rf();}

