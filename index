<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>더샵 새벽 배송 동선 최적화</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","Apple SD Gothic Neo","Noto Sans KR",sans-serif;background:#f5f4f0;color:#1a1a1a;min-height:100vh;}
  .header{background:#fff;border-bottom:1px solid #e5e4e0;padding:1rem 1.5rem;display:flex;align-items:center;gap:12px;}
  .logo{font-size:17px;font-weight:600;color:#1a1a1a;}
  .logo-sub{font-size:12px;color:#888;margin-top:1px;}
  .main{max-width:1100px;margin:0 auto;padding:1.5rem;}
  .metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:1.25rem;}
  .metric{background:#fff;border-radius:10px;border:1px solid #e5e4e0;padding:.875rem 1rem;text-align:center;}
  .metric-val{font-size:22px;font-weight:600;color:#1a1a1a;}
  .metric-lbl{font-size:11px;color:#888;margin-top:3px;}
  .card{background:#fff;border-radius:12px;border:1px solid #e5e4e0;padding:1rem 1.25rem;margin-bottom:1rem;}
  .card-title{font-size:14px;font-weight:600;margin-bottom:.875rem;color:#1a1a1a;}
  .sr{display:flex;gap:8px;margin-bottom:.75rem;flex-wrap:wrap;}
  input,select{flex:1;min-width:120px;border:1px solid #ddd;border-radius:8px;padding:8px 10px;font-size:13px;background:#fff;color:#1a1a1a;outline:none;}
  input:focus,select:focus{border-color:#534AB7;}
  button{border:1px solid #ddd;border-radius:8px;padding:8px 14px;font-size:13px;cursor:pointer;background:#fff;color:#1a1a1a;transition:background .15s;}
  button:hover{background:#f5f4f0;}
  button.pri{background:#534AB7;color:#fff;border-color:#534AB7;font-weight:500;}
  button.pri:hover{background:#3C3489;}
  .plist{max-height:220px;overflow-y:auto;border:1px solid #e5e4e0;border-radius:8px;margin-bottom:.5rem;}
  .pi{display:flex;align-items:center;gap:8px;padding:8px 10px;border-bottom:1px solid #f0eeea;cursor:pointer;font-size:13px;transition:background .1s;}
  .pi:last-child{border-bottom:none;}
  .pi:hover,.pi.sel{background:#f5f4f0;}
  .chk{width:17px;height:17px;border:1.5px solid #ccc;border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;transition:all .15s;}
  .chk.on{background:#534AB7;border-color:#534AB7;color:#fff;}
  .br{display:flex;justify-content:space-between;align-items:center;margin-top:.5rem;}
  .scnt{font-size:12px;color:#888;}
  .brow{display:flex;gap:6px;}
  .vcnt-row{display:flex;align-items:center;gap:10px;}
  .vcnt-row label{font-size:13px;color:#555;}
  .tabs{display:flex;border-bottom:1px solid #e5e4e0;margin-bottom:1rem;}
  .tab{padding:9px 18px;font-size:13px;cursor:pointer;color:#888;border-bottom:2px solid transparent;margin-bottom:-1px;transition:color .15s;}
  .tab.on{color:#534AB7;border-bottom-color:#534AB7;font-weight:500;}
  #mapwrap{border-radius:10px;overflow:hidden;border:1px solid #e5e4e0;height:440px;margin-bottom:1rem;}
  .cars{display:grid;grid-template-columns:repeat(2,1fr);gap:.875rem;}
  .cc{background:#fff;border:1px solid #e5e4e0;border-radius:12px;padding:.875rem 1rem;}
  .ch{display:flex;align-items:center;gap:10px;margin-bottom:.65rem;}
  .cbadge{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;flex-shrink:0;}
  .ct{font-size:14px;font-weight:600;}
  .cm{font-size:11px;color:#888;margin-top:1px;}
  .ri{display:flex;gap:8px;padding:6px 0;border-bottom:1px solid #f0eeea;align-items:flex-start;}
  .ri:last-child{border-bottom:none;}
  .sn{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;flex-shrink:0;}
  .rname{font-size:12px;font-weight:600;flex:1;min-width:0;}
  .raddr{font-size:10px;color:#888;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  .rw{font-size:10px;margin-top:2px;}
  .rtime{font-size:10px;flex-shrink:0;font-weight:600;}
  .cstat{display:flex;gap:12px;margin-top:.65rem;padding-top:.65rem;border-top:1px solid #f0eeea;}
  .cs{font-size:11px;color:#888;}
  .cs span{color:#1a1a1a;font-weight:600;}
  .zpills{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:.5rem;}
  .zp{font-size:10px;padding:2px 8px;border-radius:9px;}
  .abox{border-radius:8px;padding:.6rem 1rem;font-size:12px;margin-bottom:.65rem;}
  .aw{background:#fef2f2;border:1px solid #fca5a5;color:#7f1d1d;}
  .ai{background:#eff6ff;border:1px solid #93c5fd;color:#1e3a5f;}
  .win-tag{font-size:10px;padding:2px 7px;border-radius:8px;display:inline-block;font-weight:500;}
  .win-before{background:#fef3c7;color:#78350f;}
  .win-after{background:#d1fae5;color:#064e3b;}
  .win-blocked{background:#fee2e2;color:#7f1d1d;}
  .map-legend{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:.75rem;}
  .leg-item{display:flex;align-items:center;gap:5px;font-size:12px;color:#555;}
  .leg-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0;}
  .leg-sq{width:12px;height:12px;border-radius:3px;flex-shrink:0;}
  @media(max-width:600px){
    .metrics{grid-template-columns:repeat(2,1fr);}
    .cars{grid-template-columns:1fr;}
    .sr{flex-direction:column;}
  }
</style>
</head>
<body>

<div class="header">
  <div>
    <div class="logo">더샵 새벽 배송 동선</div>
    <div class="logo-sub">출발지: 김포시 고촌읍 아라육로57번길 45 &nbsp;|&nbsp; 배송 시간대: 21:00 ~ 02:00</div>
  </div>
</div>

<div class="main">
  <div class="metrics" id="metrics"></div>

  <div class="card">
    <div class="card-title">오늘 주문 약국 선택</div>
    <div class="sr">
      <input type="text" id="sq" placeholder="약국명 또는 주소 검색..." oninput="rf()">
      <select id="sg" onchange="rf()"><option value="">전체 구군</option></select>
      <select id="scf" onchange="rf()">
        <option value="">건물폐쇄 전체</option>
        <option value="y">폐쇄 약국만</option>
        <option value="n">제약 없음만</option>
      </select>
    </div>
    <div class="plist" id="plist"></div>
    <div class="br">
      <span class="scnt" id="scnt">0개 선택됨</span>
      <div class="brow">
        <button onclick="sa()">전체 선택</button>
        <button onclick="ca()">선택 해제</button>
      </div>
    </div>
  </div>

  <div class="card" style="padding:.875rem 1.25rem;">
    <div class="vcnt-row">
      <label>오늘 배송 차량 수</label>
      <select id="vcnt" style="flex:0;min-width:80px;width:80px;">
        <option value="1">1대</option>
        <option value="2">2대</option>
        <option value="3">3대</option>
        <option value="4" selected>4대</option>
        <option value="5">5대</option>
      </select>
      <button class="pri" onclick="build()" style="margin-left:auto;">동선 생성</button>
    </div>
  </div>

  <div id="result" style="display:none;">
    <div id="alerts"></div>

    <div class="card" style="padding:1rem 1.25rem;">
      <div class="tabs">
        <div class="tab on" id="tab-map" onclick="switchTab('map')">지도 보기</div>
        <div class="tab" id="tab-list" onclick="switchTab('list')">목록 보기</div>
      </div>

      <div id="view-map">
        <div class="map-legend" id="legend"></div>
        <div id="mapwrap"><div id="map" style="width:100%;height:100%;"></div></div>
      </div>

      <div id="view-list" style="display:none;">
        <div class="cars" id="cargrid"></div>
      </div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
const DEPOT={lat:37.6082,lng:126.7896,name:"김포 고촌 물류지"};

const GU_POS={
  "강서구":{lat:37.551,lng:126.849},"마포구":{lat:37.566,lng:126.901},"관악구":{lat:37.479,lng:126.952},
  "영등포구":{lat:37.527,lng:126.896},"종로구":{lat:37.573,lng:126.979},"서대문구":{lat:37.579,lng:126.937},
  "중랑구":{lat:37.606,lng:127.093},"양천구":{lat:37.527,lng:126.856},"노원구":{lat:37.654,lng:127.056},
  "동대문구":{lat:37.574,lng:127.040},"성북구":{lat:37.589,lng:127.017},"은평구":{lat:37.601,lng:126.928},
  "중구":{lat:37.563,lng:126.998},"동작구":{lat:37.511,lng:126.942},"용산구":{lat:37.531,lng:126.990},
  "구로구":{lat:37.494,lng:126.887},"금천구":{lat:37.457,lng:126.895},"김포시":{lat:37.615,lng:126.716}
};

const GU_JITTER={};
function getPos(p){
  const base=GU_POS[p.g]||{lat:37.56,lng:126.97};
  if(!GU_JITTER[p.id]) GU_JITTER[p.id]={lat:(Math.random()-.5)*.018,lng:(Math.random()-.5)*.022};
  return{lat:base.lat+GU_JITTER[p.id].lat,lng:base.lng+GU_JITTER[p.id].lng};
}

function guDist(gu){const p=GU_POS[gu]||{lat:37.56,lng:126.97};const dy=p.lat-DEPOT.lat,dx=(p.lng-DEPOT.lng)*Math.cos(37.56*Math.PI/180);return Math.sqrt(dy*dy+dx*dx)*111;}
function guAngle(gu){const p=GU_POS[gu]||{lat:37.56,lng:126.97};return Math.atan2(p.lat-DEPOT.lat,(p.lng-DEPOT.lng)*Math.cos(37.56*Math.PI/180));}

function toMin(hm){
  if(!hm||hm==="없음") return null;
  const[h,m]=hm.split(":").map(Number);
  let v=h*60+m; if(h<12) v+=1440; return v-1260;
}
function minToLabel(min){
  const total=((min+1260)%1440+1440)%1440;
  const h=Math.floor(total/60)%24,m=total%60;
  return String(h).padStart(2,'0')+":"+String(m).padStart(2,'0');
}
function getWin(p){
  if(!p.fs||p.fs==="없음") return{type:'free',label:"전 시간 가능"};
  const s=toMin(p.fs),e=toMin(p.fe);
  if(s===null||e===null) return{type:'free',label:"전 시간 가능"};
  if(s>=0&&s<300) return{type:'before',label:`${p.fs} 전 배송 필수`,deadline:s};
  if(s<0&&e>0&&e<300) return{type:'after',label:`${minToLabel(e)} 이후 배송`,available:e};
  if(s<=0&&e>=300) return{type:'blocked',label:"배송시간 전체 폐쇄"};
  return{type:'free',label:"전 시간 가능"};
}

