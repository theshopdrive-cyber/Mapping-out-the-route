function makeIcon(color,num,isWarn){
  const bg=isWarn?'#D85A30':color;
  const svg=`<svg xmlns="http://www.w3.org/2000/svg" width="28" height="34" viewBox="0 0 28 34">
    <path d="M14 0C6.27 0 0 6.27 0 14c0 9.33 14 20 14 20S28 23.33 28 14C28 6.27 21.73 0 14 0z" fill="${bg}"/>
    <circle cx="14" cy="13" r="8" fill="white" fill-opacity="0.92"/>
    <text x="14" y="17" text-anchor="middle" font-size="9" font-weight="bold" fill="${bg}">${num}</text>
  </svg>`;
  return L.divIcon({html:svg,iconSize:[28,34],iconAnchor:[14,34],popupAnchor:[0,-36],className:''});
}

